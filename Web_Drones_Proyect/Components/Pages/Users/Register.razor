@page "/register"
@using System.Security.Cryptography
@using System.Text
@using Web_Drones_Proyect.Models
@using Web_Drones_Proyect.Data.Repositories
@using MudBlazor
@using Web_Drones_Proyect.Services

<!-- ===================== -->
<!-- Contenedor principal de registro -->
<!-- ===================== -->
<div class="auth-bg">
    <div class="auth-shell">

        <!-- Tarjeta del formulario -->
        <div class="auth-card">

            <!-- Identidad / marca del sistema -->
            <div class="brand-row">
                <div class="brand-badge">Aero Santo Domingo</div>
                <div class="brand-dot" aria-hidden="true"></div>
            </div>

            <!-- Título -->
            <MudText Typo="Typo.h4" Class="auth-title">
                Crear Cuenta
            </MudText>

            <!-- Subtítulo -->
            <MudText Typo="Typo.body2" Class="auth-subtitle">
                Completa tus datos para registrarte.
            </MudText>

            <!-- ===================== -->
            <!-- Formulario de registro -->
            <!-- ===================== -->
            <MudForm @ref="_form" Class="auth-form">

                <!-- Nombre de usuario -->
                <MudTextField Label="Nombre"
                              TValue="string"
                              Value="_user.UserName"
                              ValueChanged="@((string v) => _user.UserName = v)"
                              ValueExpression="@(() => _user.UserName)"
                              Required="true"
                              Variant="Variant.Outlined"
                              Class="auth-input" />

                <!-- Correo electrónico -->
                <MudTextField Label="Correo Electrónico"
                              TValue="string"
                              InputType="InputType.Email"
                              Value="_user.Email"
                              ValueChanged="@((string v) => _user.Email = v)"
                              ValueExpression="@(() => _user.Email)"
                              Required="true"
                              RequiredError="El correo es obligatorio"
                              Immediate="true"
                              Validation="ValidateEmail"
                              Variant="Variant.Outlined"
                              Class="auth-input" />

                <!-- Contraseña -->
                <MudTextField Label="Contraseña"
                              TValue="string"
                              InputType="@(_showPassword? InputType.Text: InputType.Password)"
                              Value="_password"
                              ValueChanged="@((string v) => _password = v)"
                              ValueExpression="@(() => _password)"
                              Required="true"
                              Variant="Variant.Outlined"
                              Class="auth-input"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="TogglePasswordVisibility" />

                <!-- Confirmación de contraseña -->
                <MudTextField Label="Confirmar Contraseña"
                              TValue="string"
                              InputType="@(_showConfirmPassword? InputType.Text: InputType.Password)"
                              Value="_confirmPassword"
                              ValueChanged="@((string v) => _confirmPassword = v)"
                              ValueExpression="@(() => _confirmPassword)"
                              Required="true"
                              Variant="Variant.Outlined"
                              Class="auth-input"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showConfirmPassword? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="ToggleConfirmPasswordVisibility" />

                <!-- Botón de registro -->
                <MudButton Class="auth-btn"
                           OnClick="RegisterAsync"
                           FullWidth="true">
                    Registrarse
                </MudButton>

            </MudForm>

            <!-- Mensaje de error -->
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="auth-alert">
                    @_errorMessage
                </MudAlert>
            }

            <!-- Enlace para iniciar sesión -->
            <div class="auth-foot">
                <span>¿Ya tienes cuenta?</span>
                <a class="auth-link" href="/login">Iniciar sesión</a>
            </div>

        </div>
    </div>
</div>

<style>
    :root {
        --teal-0: #E0F2F1;
        --teal-1: #B2DFDB;
        --teal-2: #80CBC4;
        --teal-3: #4DB6AC;
        --teal-4: #26A69A;
        --teal-5: #009688;
        --teal-d2: #00796B;
        --teal-d3: #00695C;
        --teal-d4: #004D40;
        --ink: #083B33;
        --muted: rgba(8,59,51,.72);
        --border: rgba(0,77,64,.14);
        --shadow: rgba(0,77,64,.18);
    }

    .auth-bg {
        min-height: calc(100vh - 64px);
        padding: 3.2rem 1rem;
        display: grid;
        place-items: center;
        background: radial-gradient(900px 400px at 20% 10%, rgba(29,233,182,.22), transparent 60%), radial-gradient(700px 320px at 85% 18%, rgba(38,166,154,.18), transparent 55%), linear-gradient(180deg, var(--teal-0), #F6FFFE 55%, var(--teal-1));
        position: relative;
        overflow: hidden;
    }

        .auth-bg::before,
        .auth-bg::after {
            content: "";
            position: absolute;
            width: 520px;
            height: 520px;
            border-radius: 50%;
            filter: blur(40px);
            opacity: .55;
            pointer-events: none;
            animation: floatBlob 10s ease-in-out infinite;
        }

        .auth-bg::before {
            left: -180px;
            top: 80px;
            background: radial-gradient(circle, rgba(0,191,165,.35), transparent 60%);
        }

        .auth-bg::after {
            right: -220px;
            bottom: -80px;
            background: radial-gradient(circle, rgba(38,166,154,.28), transparent 60%);
            animation-delay: 1.6s;
        }

    .auth-shell {
        width: 100%;
        max-width: 480px;
        position: relative;
        z-index: 1;
    }

    .auth-card {
        border-radius: 22px;
        padding: 2rem 2rem 1.3rem;
        background: rgba(255,255,255,.78);
        border: 1px solid var(--border);
        backdrop-filter: blur(10px);
        box-shadow: 0 18px 55px var(--shadow), 0 1px 0 rgba(255,255,255,.9) inset;
        transform: translateY(8px);
        opacity: 0;
        animation: fadeUp .7s ease forwards;
        position: relative;
        overflow: hidden;
    }

        .auth-card::before {
            content: "";
            position: absolute;
            inset: -120px -120px auto -120px;
            height: 220px;
            background: radial-gradient(circle at 30% 40%, rgba(29,233,182,.22), transparent 60%);
            pointer-events: none;
        }

    .brand-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: .9rem;
    }

    .brand-badge {
        width: fit-content;
        padding: .38rem .75rem;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(0,150,136,.14), rgba(38,166,154,.10));
        border: 1px solid rgba(0,150,136,.20);
        color: var(--teal-d3);
        font-weight: 900;
        letter-spacing: .2px;
        animation: fadeUp .7s ease .08s forwards;
        opacity: 0;
    }

    .brand-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #1DE9B6;
        box-shadow: 0 0 0 7px rgba(29,233,182,.18);
        animation: pulse 2.2s ease-in-out infinite;
    }

    .auth-title {
        color: var(--ink);
        font-weight: 950;
        letter-spacing: -.2px;
        margin: 0;
        animation: fadeUp .7s ease .12s forwards;
        opacity: 0;
    }

    .auth-subtitle {
        color: var(--muted);
        margin-top: .35rem;
        animation: fadeUp .7s ease .18s forwards;
        opacity: 0;
    }

    .auth-form {
        margin-top: 1.25rem;
        display: grid;
        gap: .95rem;
        animation: fadeUp .7s ease .24s forwards;
        opacity: 0;
    }

    .auth-input .mud-input-control {
        border-radius: 14px;
        background: rgba(255,255,255,.75);
    }

    .auth-input .mud-input-outlined-border {
        border-color: rgba(0,77,64,.20) !important;
    }

    .auth-input:hover .mud-input-outlined-border {
        border-color: rgba(0,150,136,.35) !important;
    }

    .auth-input .mud-input-label {
        color: rgba(8,59,51,.62) !important;
