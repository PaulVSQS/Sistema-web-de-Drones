        background: linear-gradient(90deg, var(--teal-4), var(--teal-d2)) !important;
        box-shadow: 0 14px 26px rgba(0,77,64,.22);
        transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
    }

        .auth-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 34px rgba(0,77,64,.30);
            filter: saturate(1.05);
        }

        .auth-btn:active {
            transform: translateY(0px);
            box-shadow: 0 10px 18px rgba(0,77,64,.20);
        }

    .auth-alert {
        margin-top: 1rem;
        border-radius: 14px;
    }

    .auth-foot {
        margin-top: 1.15rem;
        display: flex;
        justify-content: center;
        gap: .5rem;
        color: rgba(8,59,51,.70);
        font-weight: 700;
    }

    .auth-link {
        color: var(--teal-d3);
        font-weight: 950;
        text-decoration: none;
    }

        .auth-link:hover {
            text-decoration: underline;
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(14px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes floatBlob {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-18px);
        }

        100% {
            transform: translateY(0px);
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
            box-shadow: 0 0 0 7px rgba(29,233,182,.18);
        }

        50% {
            transform: scale(1.08);
            box-shadow: 0 0 0 10px rgba(29,233,182,.14);
        }
    }
</style>

@code {
    // Control de visibilidad de contraseñas
    private bool _showPassword = false;
    private bool _showConfirmPassword = false;

    // Referencia al formulario MudBlazor
    private MudForm _form = default!;

    // Modelo temporal del usuario
    private UserEntity _user = new();

    // Campos de contraseña
    private string _password = string.Empty;
    private string _confirmPassword = string.Empty;

    // Mensaje de error mostrado al usuario
    private string? _errorMessage;

    // Repositorio para acceso a usuarios en la base de datos
    [Inject] private IRepository<User> UserRepository { get; set; } = default!;

    // Servicio de navegación entre páginas
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    // Notificaciones tipo snackbar
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    // Servicio de autenticación
    [Inject] private AuthService AuthService { get; set; } = default!;


    // Método principal para registrar un usuario
    private async Task RegisterAsync()
    {
        // Valida el formulario
        if (_form != null)
            await _form.Validate();

        _errorMessage = string.Empty;

        if (!_form.IsValid)
            return;

        // Verifica que las contraseñas coincidan
        if (_password != _confirmPassword)
        {
            _errorMessage = "Las contraseñas no coinciden.";
            return;
        }

        // Verifica si el correo ya existe
        var existingUser = (await UserRepository.FindAsync(u => u.Email == _user.Email))
            .FirstOrDefault();

        if (existingUser != null)
        {
            _errorMessage = "Este correo ya está registrado.";
            return;
        }

        // Crea el usuario que se guardará en la base de datos
        var userToSave = new User
        {
            UserName = _user.UserName,
            Email = _user.Email,
            PasswordHash = HashPassword(_password),
            RolID = 2, // rol por defecto para nuevos Clientes
            Active = true,
            RegistrationDate = DateTime.Now
        };

        // Guarda el usuario
        await UserRepository.AddAsync(userToSave);
        await UserRepository.SaveChangesAsync();

        // Intenta iniciar sesión automáticamente
        var loginSuccess = await AuthService.LoginAsync(_user.Email, _password);

        if (loginSuccess)
        {
            Snackbar.Add($"Bienvenido {_user.UserName}, tu cuenta fue creada correctamente.", Severity.Success);
            Navigation.NavigateTo("/");
        }
        else
        {
            Navigation.NavigateTo("/login");
        }
    }


    // Genera el hash de la contraseña usando SHA256
    private string HashPassword(string password)
    {
        using var sha256 = SHA256.Create();
        var bytes = Encoding.UTF8.GetBytes(password);
        var hash = sha256.ComputeHash(bytes);
        return Convert.ToBase64String(hash);
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        _showConfirmPassword = !_showConfirmPassword;
    }

    private string? ValidateEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email))
            return "El correo es obligatorio";

        var regex = new System.Text.RegularExpressions.Regex(
            @"^[^@\s]+@[^@\s]+\.[^@\s]+$");

        return regex.IsMatch(email)
            ? null
            : "Formato de correo inválido";
    }
}