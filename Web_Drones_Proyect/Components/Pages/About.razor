@page "/About"

<!-- Contenedor principal de la página About -->
<div class="about-wrap">

    <!-- HERO: sección principal de presentación -->
    <section class="about-hero">

        <!-- Texto introductorio -->
        <div class="about-hero__text">
            <!-- Etiqueta descriptiva -->
            <div class="badge">Aero Santo Domingo</div>

            <!-- Título principal -->
            <h1>Sobre Nosotros</h1>

            <!-- Descripción general de la empresa -->
            <p class="lead">
                Somos una empresa enfocada en acercar la tecnología de drones a personas y negocios,
                ofreciendo productos confiables y soluciones orientadas a resultados.
            </p>

            <!-- Lista corta de servicios y valores -->
            <div class="mini">
                <div class="mini__item">
                    <div class="mini__dot"></div>
                    <span>Venta & asesoría</span>
                </div>

                <div class="mini__item">
                    <div class="mini__dot"></div>
                    <span>Soporte & servicio</span>
                </div>

                <div class="mini__item">
                    <div class="mini__dot"></div>
                    <span>Experiencia moderna</span>
                </div>
            </div>
        </div>

        <!-- Imagen destacada del hero -->
        <div class="about-hero__media">
            <div class="image-card">
                <!-- Imagen representativa de la empresa -->
                <img src="images/page/Fotologo.jpeg" alt="Dron - Aero Santo Domingo" />
            </div>

            <!-- Efecto visual decorativo -->
            <div class="glow" aria-hidden="true"></div>
        </div>
    </section>

    <!-- QUIÉNES SOMOS Y CONTACTO -->
    <section class="about-grid">

        <!-- Información institucional -->
        <article class="panel">
            <h2>¿Quiénes somos?</h2>

            <!-- Descripción de la misión y enfoque -->
            <p>
                En <strong>Aero Santo Domingo</strong> trabajamos para ofrecer una experiencia clara y segura al
                momento de elegir un dron o un servicio relacionado. Nuestro enfoque es ayudar al cliente
                a tomar la mejor decisión según su necesidad, con información transparente y soporte real.
            </p>

            <!-- Valores principales de la empresa -->
            <div class="pill-row">
                <span class="pill">Calidad</span>
                <span class="pill">Transparencia</span>
                <span class="pill">Soporte</span>
                <span class="pill">Innovación</span>
            </div>
        </article>

        <!-- Sección de contacto -->
        <article class="panel panel--soft">
            <h2>Contacto</h2>

            <!-- Texto introductorio de contacto -->
            <p class="muted">
                ¿Tienes preguntas sobre drones, servicios o disponibilidad? Escríbenos o llámanos:
            </p>

            <!-- Información de contacto -->
            <div class="contact">

                <!-- Teléfono -->
                <div class="contact__item">
                    <div class="contact__icon">📞</div>
                    <div>
                        <div class="contact__label">Teléfono</div>
                        <div class="contact__value">+1 (849) 555-0198</div>
                    </div>
                </div>

                <!-- Correo electrónico -->
                <div class="contact__item">
                    <div class="contact__icon">✉️</div>
                    <div>
                        <div class="contact__label">Correo</div>
                        <div class="contact__value">contacto@aerosantodomingo.com</div>
                    </div>
                </div>

                <!-- Horario de atención -->
                <div class="contact__item">
                    <div class="contact__icon">📍</div>
                    <div>
                        <div class="contact__label">Horario</div>
                        <div class="contact__value">Lun–Sáb | 9:00 AM – 6:00 PM</div>
                    </div>
                </div>
            </div>

            <!-- Nota informativa adicional -->
            <div class="note">
                Responderemos lo antes posible. También puedes escribirnos por WhatsApp al mismo número.
            </div>
        </article>
    </section>
</div>

<style>

    :root {
        --teal-0: #E0F2F1;
        --teal-1: #B2DFDB;
        --teal-2: #80CBC4;
        --teal-3: #4DB6AC;
        --teal-4: #26A69A;
        --teal-5: #009688;
        --teal-d1: #00897B;
        --teal-d2: #00796B;
        --teal-d3: #00695C;
        --teal-d4: #004D40;
        --accent-1: #A7FFEB;
        --accent-2: #64FFDA;
        --accent-3: #1DE9B6;
        --accent-4: #00BFA5;
        --panel: rgba(255,255,255,.06);
        --panel2: rgba(255,255,255,.09);
        --border: rgba(255,255,255,.14);
        --text: rgba(255,255,255,.93);
        --muted: rgba(255,255,255,.72);
    }

    .about-wrap {
        padding: 1.25rem;
        color: var(--text);
        background: linear-gradient(180deg, #E0F2F1, #B2DFDB);
        min-height: 100vh;
    }


    /* HERO */
    .about-hero {
        display: grid;
        grid-template-columns: 1.15fr .85fr;
        gap: 1.75rem;
        padding: 2.6rem 1.35rem;
        border-radius: 18px;
        border: 1px solid var(--border);
        background: radial-gradient(900px 350px at 18% 10%, rgba(0,191,165,.33), transparent 60%), radial-gradient(700px 320px at 80% 25%, rgba(38,166,154,.30), transparent 55%), linear-gradient(180deg, var(--teal-d4), var(--teal-d3));
        position: relative;
        overflow: hidden;
        animation: fadeUp .8s ease forwards;
    }

    .badge {
        display: inline-flex;
        width: fit-content;
        padding: .35rem .7rem;
        border-radius: 999px;
        background: rgba(0,150,136,.18);
        border: 1px solid rgba(100,255,218,.25);
        color: var(--accent-1);
        font-weight: 700;
        letter-spacing: .2px;
        animation: fadeUp .8s ease .2s forwards;
        opacity: 0;
    }
        .badge:hover {
            animation: glowPulse 1.5s infinite;
        }


    .about-hero h1 {
        margin: .9rem 0 .6rem;
        font-size: clamp(1.9rem, 2.8vw, 3rem);
        line-height: 1.05;
    }

    .lead {
        margin: 0;
        max-width: 60ch;
        color: var(--muted);
        font-size: 1.03rem;
    }

    .mini {
        margin-top: 1.15rem;
        display: flex;
        gap: .9rem;
        flex-wrap: wrap;
    }

    .mini__item {
        display: inline-flex;
        align-items: center;
        gap: .55rem;
        padding: .45rem .8rem;
        border-radius: 999px;
        background: linear-gradient(135deg, #00796B, #004D40);
        border: 1px solid #00695C;
        color: #A7FFEB;
        font-weight: 800;
        font-size: .9rem;
        animation: fadeUp .8s ease forwards;
        opacity: 0;
        transition: all .25s ease;
    }
        .mini__item:nth-child(1) {
            animation-delay: .3s;
        }

        .mini__item:nth-child(2) {
            animation-delay: .45s;
        }

        .mini__item:nth-child(3) {
            animation-delay: .6s;
        }

    .mini__dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--accent-3);
        box-shadow: 0 0 0 5px rgba(29,233,182,.10);
    }

    .about-hero__media {
        position: relative;
        display: grid;
        place-items: center;
    }

    .image-card {
        width: 100%;
        max-width: 520px;
        padding: 1.05rem;
        border-radius: 22px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.10);
        backdrop-filter: blur(8px);
        position: relative;
        overflow: hidden;
        animation: fadeUp .9s ease .4s forwards;
        opacity: 0;
    }

        .image-card img {
            width: 100%;
            height: auto;
            display: block;
            border-radius: 18px;
            filter: drop-shadow(0 18px 40px rgba(0,0,0,.45))
            drop-shadow(0 0 25px rgba(29,233,182,.18));
            animation: floatSoft 5s ease-in-out infinite;
        }


    .glow {
        position: absolute;
        inset: -40px -60px -40px -60px;
        background: radial-gradient(circle at 60% 30%, rgba(29,233,182,.20), transparent 55%);
        pointer-events: none;
    }

    /* GRID */
    .about-grid {
        margin-top: 1.25rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.15rem;

    }

    .panel {
        background: rgba(0, 77, 64, .06);
        border: 1px solid rgba(0, 77, 64, .12);
        border-radius: 18px;
        padding: 1.35rem 1.35rem 1.15rem;
        color: #00352E;
        transition: all .3s ease;
    }

        .panel:hover {
            box-shadow: 0 10px 30px rgba(0,0,0,.25), 0 0 20px rgba(29,233,182,.12);
            transform: translateY(-3px);
        }

    .panel--soft {
        background: var(--panel2);
    }

    .panel p {
        color: rgba(0, 53, 46, .75);
    }

    .panel h2 {
        color: #00352E;
    }

    .muted {
        color: rgba(0, 53, 46, .70);
    }


    .pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
        margin-top: .2rem;
    }

    .pill {
        background: linear-gradient(135deg, #00796B, #004D40);
        border: 1px solid #00695C;
        color: #A7FFEB;
        padding: .45rem .75rem;
        border-radius: 999px;
        font-weight: 800;
        font-size: .85rem;
        box-shadow: 0 4px 10px rgba(0,0,0,.15);
        transition: all .25s ease;
    }

        .pill:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,.35), 0 0 12px rgba(29,233,182,.35);
        }



    /* CONTACT */
    .contact {
        display: grid;
        gap: .75rem;
        margin-top: .8rem;
    }

    .contact__item {
        display: grid;
        grid-template-columns: 44px 1fr;
        gap: .8rem;
        align-items: center;
        padding: 1rem;
        border-radius: 16px;
        background: linear-gradient(135deg, #00695C, #004D40);
        border: 1px solid #00796B;
        box-shadow: 0 6px 18px rgba(0,0,0,.25);
        transition: all .3s ease;
        position: relative;
        overflow: hidden;
    }

        .contact__item:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 28px rgba(0,0,0,.4), 0 0 18px rgba(29,233,182,.25);
        }

        .contact__item::before {
            content: "";
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(29,233,182,.15) 0%, transparent 60%);
            opacity: 0;
            transition: opacity .4s ease;
            pointer-events: none;
        }

        .contact__item:hover::before {
            opacity: 1;
        }



    .contact__icon {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        background: rgba(0,191,165,.18);
        border: 1px solid rgba(100,255,218,.35);
        font-size: 1.1rem;
        transition: all .3s ease;
    }

    .contact__item:hover .contact__icon {
        transform: scale(1.15) rotate(5deg);
        background: rgba(29,233,182,.25);
    }


    .contact__label {
        color: #80CBC4;
        font-weight: 700;
        font-size: .9rem;
        margin-bottom: .15rem;
    }

    .contact__value {
        color: #E0F2F1;
        font-weight: 900;
        letter-spacing: .3px;
    }


    .note {
        margin-top: .9rem;
        padding: 1rem;
        border-radius: 16px;
        background: linear-gradient(135deg, #00897B, #00695C);
        border: 1px solid #009688;
        color: #E0F2F1;
        font-weight: 700;
        box-shadow: 0 4px 12px rgba(0,0,0,.2);
    }


    /* Responsive */
    @@media (max-width: 900px) {
        .about-hero {
            grid-template-columns: 1fr;
        }

        .about-grid {
            grid-template-columns: 1fr;
        }
    }


    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(25px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes floatSoft {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-8px);
        }

        100% {
            transform: translateY(0px);
        }
    }

    @@keyframes glowPulse {
        0% {
            box-shadow: 0 0 0 rgba(29,233,182,0);
        }

        50% {
            box-shadow: 0 0 25px rgba(29,233,182,.35);
        }

        100% {
            box-shadow: 0 0 0 rgba(29,233,182,0);
        }
    }

</style>
